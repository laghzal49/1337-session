{
	"agent": {
  "default_model": {
   "provider": "copilot_chat",
   "model": "gpt-5-mini",
   "enable_thinking": false,
   "effort": "high"
  },
  "favorite_models": [],
  "model_parameters": []
 },
 "theme": "One Dark Pro",

	"buffer_font_family": "Noto Sans Anatolian Hieroglyphs",
	"buffer_font_size": 15,

	"autosave": {
		"after_delay": { "milliseconds": 1000 },
	},

	"minimap": { "show": "never" },

	"tab_bar": { "show": true },

	"tabs": {
		"file_icons": true,
		"git_status": true,
	},

	"project_panel": { "dock": "left" },

	"file_scan_exclusions": [
		"**/.trunk/*actions/",
		"**/.trunk/*logs/",
		"**/.trunk/*notifications/",
		"**/.trunk/*out/",
		"**/.trunk/*plugins/",
	],

	"git": { "inline_blame": { "enabled": true } },
	"disable_ai": false,
	"confirm_quit": false,
	"tab_size": 4,
	"hard_tabs": true,
	"vim_mode": true,
}

